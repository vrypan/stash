#!/usr/bin/env bash
set -euo pipefail

if ! command -v stash >/dev/null 2>&1; then
  echo "error: stash is required" >&2
  exit 1
fi

usage() {
  cat >&2 <<'EOF'
usage:
  bookmark <url>
  bookmark add <url>
  bookmark ls
  bookmark open <ref>
  bookmark title <ref> <title>
  bookmark grep <pattern> [rg args...]
  bookmark find <pattern> [rg args...]
  bookmark findx <pattern> [rg args...]
EOF
  exit 1
}

bookmark_add() {
  local url="$1"

  if ! command -v curl >/dev/null 2>&1; then
    echo "error: curl is required" >&2
    exit 1
  fi

  if ! command -v html2text >/dev/null 2>&1; then
    echo "error: html2text is required" >&2
    exit 1
  fi

  local html
  html="$(curl -fsSL "$url")"

  local title
  title="$(
    printf '%s\n' "$html" \
      | awk '
          { html = html $0 "\n" }
          END {
            lower = tolower(html)
            if (!match(lower, /<title([[:space:]][^>]*)?>/)) {
              exit
            }

            title = substr(html, RSTART + RLENGTH)
            lower_title = substr(lower, RSTART + RLENGTH)
            if (!match(lower_title, /<\/title[[:space:]]*>/)) {
              exit
            }

            print substr(title, 1, RSTART - 1)
          }
        ' \
      | html2text -width 1000 \
      | sed -e 's/\r$//' \
      | awk 'NF { print; exit }'
  )"

  if [[ -z "$title" ]]; then
    title="$url"
  fi

  local text
  text="$(printf '%s\n' "$html" | html2text -width 1000)"

  printf '%s\n' "$text" \
    | stash push \
        --attr "url=$url" \
        --attr "title=$title" \
        --attr "pocket=bookmarks"

  printf 'URL: %s\nTitle: %s\n' "$url" "$title"
}

bookmark_ls() {
  stash ls --date -a +title -a +url -a pocket=bookmarks
}

bookmark_open() {
  local ref="$1"
  local url
  url="$(stash attr "$ref" url 2>/dev/null)" || true

  if [[ -z "$url" ]]; then
    echo "error: no url attribute found for '$ref'" >&2
    exit 1
  fi

  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  else
    echo "error: cannot open URL: neither 'open' nor 'xdg-open' found" >&2
    exit 1
  fi
}

bookmark_title() {
  local ref="$1"
  shift
  local title="$*"

  local pocket
  pocket="$(stash attr "$ref" pocket 2>/dev/null)" || true

  if [[ "$pocket" != "bookmarks" ]]; then
    echo "error: '$ref' is not a bookmark" >&2
    exit 1
  fi

  stash attr "$ref" "title=$title"
}

bookmark_grep() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  if ! command -v rg >/dev/null 2>&1; then
    echo "error: rg is required" >&2
    exit 1
  fi

  local pattern="$1"
  shift
  local rg_args=("$@")

  local stash_dir="${STASH_DIR:-$HOME/.stash}"
  local attr_dir="$stash_dir/attr"
  local data_dir="$stash_dir/data"

  if [[ ! -d "$attr_dir" || ! -d "$data_dir" ]]; then
    echo "error: stash directories not found under $stash_dir" >&2
    exit 1
  fi

  local -a data_paths=()
  local attr_file id pocket line key value

  shopt -s nullglob
  for attr_file in "$attr_dir"/*; do
    [[ -f "$attr_file" ]] || continue
    id="${attr_file##*/}"
    pocket=""
    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      if [[ "$key" == "pocket" ]]; then
        pocket="$value"
        break
      fi
    done < "$attr_file"

    if [[ "$pocket" == "bookmarks" && -f "$data_dir/$id" ]]; then
      data_paths+=("$data_dir/$id")
    fi
  done
  shopt -u nullglob

  if [[ ${#data_paths[@]} -eq 0 ]]; then
    exit 0
  fi

  strip_ansi() {
    printf '%s' "$1" | sed -E $'s/\x1B\\[[0-9;]*m//g'
  }

  bookmark_meta() {
    local id="$1"
    local attr_file="$attr_dir/$id"
    local ts=""
    local url=""
    local line key value

    [[ -f "$attr_file" ]] || return 1

    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        ts) ts="$value" ;;
        url) url="$value" ;;
      esac
    done < "$attr_file"

    printf '%s\t%s\n' "${ts%%T*}" "$url"
  }

  local path rest match id id_short meta date url
  while IFS= read -r line; do
    path="${line%%:*}"
    rest="${line#*:}"
    match="${rest#*:}"
    path="$(strip_ansi "$path")"
    id="${path##*/}"
    id_short="${id: -8}"
    meta="$(bookmark_meta "$id")" || continue
    date="${meta%%	*}"
    url="${meta#*	}"
    printf '%s\t%s\t%s\t%b\n' \
      "$id_short" \
      "$date" \
      "$url" \
      "$match"
  done < <(
    if (( ${#rg_args[@]} == 0 )); then
      rg -n -H --color=always \
        --colors 'path:none' \
        --colors 'line:none' \
        --colors 'column:none' \
        -- "$pattern" "${data_paths[@]}" || true
    else
      rg -n -H --color=always \
        --colors 'path:none' \
        --colors 'line:none' \
        --colors 'column:none' \
        "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
    fi
  )
}

bookmark_find() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  if ! command -v rg >/dev/null 2>&1; then
    echo "error: rg is required" >&2
    exit 1
  fi

  local pattern="$1"
  shift
  local rg_args=("$@")

  local stash_dir="${STASH_DIR:-$HOME/.stash}"
  local attr_dir="$stash_dir/attr"
  local data_dir="$stash_dir/data"

  if [[ ! -d "$attr_dir" || ! -d "$data_dir" ]]; then
    echo "error: stash directories not found under $stash_dir" >&2
    exit 1
  fi

  bookmark_summary() {
    local id="$1"
    local attr_file="$attr_dir/$id"
    local pocket=""
    local ts=""
    local title=""
    local url=""
    local line key value

    [[ -f "$attr_file" ]] || return 1

    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        pocket) pocket="$value" ;;
        ts) ts="$value" ;;
        title) title="$value" ;;
        url) url="$value" ;;
      esac
    done < "$attr_file"

    [[ "$pocket" == "bookmarks" ]] || return 1
    printf '%s\t%s\t%s\n' "${ts%%T*}" "$title" "$url"
  }

  local -a data_paths=()
  local attr_file id pocket line key value

  shopt -s nullglob
  for attr_file in "$attr_dir"/*; do
    [[ -f "$attr_file" ]] || continue
    id="${attr_file##*/}"
    pocket=""
    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      if [[ "$key" == "pocket" ]]; then
        pocket="$value"
        break
      fi
    done < "$attr_file"

    if [[ "$pocket" == "bookmarks" && -f "$data_dir/$id" ]]; then
      data_paths+=("$data_dir/$id")
    fi
  done
  shopt -u nullglob

  if [[ ${#data_paths[@]} -eq 0 ]]; then
    exit 0
  fi

  local path id
  local dim=""
  local reset=""
  if [[ -t 1 ]]; then
    dim=$'\033[2m'
    reset=$'\033[0m'
  fi

  strip_ansi() {
    printf '%s' "$1" | sed -E $'s/\x1B\\[[0-9;]*m//g'
  }

  print_find_result() {
    local id="$1"
    local id_short summary date title url

    id_short="${id: -8}"
    summary="$(bookmark_summary "$id")" || return 1
    date="${summary%%	*}"
    summary="${summary#*	}"
    title="${summary%%	*}"
    url="${summary#*	}"
    printf '%s%s%s %s\n' "$dim" "$date" "$reset" "$title"
    printf '%s>>%s %s%s\n' "$dim" "$id_short" "$url" "$reset"
  }

  while IFS= read -r path; do
    path="$(strip_ansi "$path")"
    id="${path##*/}"
    print_find_result "$id" || continue
    printf '\n'
  done < <(
    if (( ${#rg_args[@]} == 0 )); then
      rg -i -l --color=never -- "$pattern" "${data_paths[@]}" || true
    else
      rg -i -l --color=never "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
    fi
  )
}

bookmark_findx() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  if ! command -v rg >/dev/null 2>&1; then
    echo "error: rg is required" >&2
    exit 1
  fi

  local pattern="$1"
  shift
  local rg_args=("$@")

  local stash_dir="${STASH_DIR:-$HOME/.stash}"
  local attr_dir="$stash_dir/attr"
  local data_dir="$stash_dir/data"

  if [[ ! -d "$attr_dir" || ! -d "$data_dir" ]]; then
    echo "error: stash directories not found under $stash_dir" >&2
    exit 1
  fi

  bookmark_summary() {
    local id="$1"
    local attr_file="$attr_dir/$id"
    local pocket=""
    local ts=""
    local title=""
    local url=""
    local line key value

    [[ -f "$attr_file" ]] || return 1

    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        pocket) pocket="$value" ;;
        ts) ts="$value" ;;
        title) title="$value" ;;
        url) url="$value" ;;
      esac
    done < "$attr_file"

    [[ "$pocket" == "bookmarks" ]] || return 1
    printf '%s\t%s\t%s\n' "${ts%%T*}" "$title" "$url"
  }

  local -a data_paths=()
  local attr_file id pocket line key value

  shopt -s nullglob
  for attr_file in "$attr_dir"/*; do
    [[ -f "$attr_file" ]] || continue
    id="${attr_file##*/}"
    pocket=""
    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      if [[ "$key" == "pocket" ]]; then
        pocket="$value"
        break
      fi
    done < "$attr_file"

    if [[ "$pocket" == "bookmarks" && -f "$data_dir/$id" ]]; then
      data_paths+=("$data_dir/$id")
    fi
  done
  shopt -u nullglob

  if [[ ${#data_paths[@]} -eq 0 ]]; then
    exit 0
  fi

  local path rest line_no match id_short summary date title url
  local current_id=""
  local printed_any=0
  local dim=""
  local reset=""
  local rg_color="never"
  if [[ -t 1 ]]; then
    dim=$'\033[2m'
    reset=$'\033[0m'
    rg_color="always"
  fi

  strip_ansi() {
    printf '%s' "$1" | sed -E $'s/\x1B\\[[0-9;]*m//g'
  }

  print_find_result() {
    local id="$1"
    local id_short summary date title url

    id_short="${id: -8}"
    summary="$(bookmark_summary "$id")" || return 1
    date="${summary%%	*}"
    summary="${summary#*	}"
    title="${summary%%	*}"
    url="${summary#*	}"
    printf '%s%s%s %s\n' "$dim" "$date" "$reset" "$title"
    printf '%s>>%s %s%s\n' "$dim" "$id_short" "$url" "$reset"
  }

  while IFS= read -r line; do
    path="${line%%:*}"
    rest="${line#*:}"
    line_no="${rest%%:*}"
    match="${rest#*:}"
    path="$(strip_ansi "$path")"
    line_no="$(strip_ansi "$line_no")"
    id="${path##*/}"
    if [[ "$id" != "$current_id" ]]; then
      if (( printed_any )); then
        printf '\n'
      fi
      print_find_result "$id" || continue
      current_id="$id"
      printed_any=1
    fi
    printf '  %s%s:%s %s\n' "$dim" "$line_no" "$reset" "$match"

  done < <(
    if (( ${#rg_args[@]} == 0 )); then
      rg -i -n -H --color="$rg_color" \
        --colors 'path:none' \
        --colors 'line:none' \
        --colors 'column:none' \
        -- "$pattern" "${data_paths[@]}" || true
    else
      rg -i -n -H --color="$rg_color" \
        --colors 'path:none' \
        --colors 'line:none' \
        --colors 'column:none' \
        "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
    fi
  )
  if (( printed_any )); then
    printf '\n'
  fi
}

if [[ $# -eq 0 ]]; then
  usage
fi

case "$1" in
  ls)
    shift
    [[ $# -eq 0 ]] || usage
    bookmark_ls
    ;;
  add)
    shift
    [[ $# -eq 1 ]] || usage
    bookmark_add "$1"
    ;;
  open)
    shift
    [[ $# -eq 1 ]] || usage
    bookmark_open "$1"
    ;;
  title)
    shift
    [[ $# -ge 2 ]] || usage
    bookmark_title "$@"
    ;;
  grep)
    shift
    bookmark_grep "$@"
    ;;
  find)
    shift
    bookmark_find "$@"
    ;;
  findx)
    shift
    bookmark_findx "$@"
    ;;
  -*)
    usage
    ;;
  *)
    [[ $# -eq 1 ]] || usage
    bookmark_add "$1"
    ;;
esac
