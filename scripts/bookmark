#!/usr/bin/env bash
set -euo pipefail

if ! command -v stash >/dev/null 2>&1; then
  echo "error: stash is required" >&2
  exit 1
fi

usage() {
  cat >&2 <<'EOF'
usage:
  bookmark <url>
  bookmark add <url>
  bookmark ls
  bookmark open <ref>
  bookmark title <ref> <title>
  bookmark grep <pattern> [rg args...]
  bookmark find <pattern> [rg args...]
EOF
  exit 1
}

bookmark_use_pager() {
  [[ -t 1 && -z "${BOOKMARK_NO_PAGER:-}" ]]
}

bookmark_pager() {
  local -a pager_cmd
  if [[ -n "${PAGER:-}" ]]; then
    read -r -a pager_cmd <<< "$PAGER"
  elif command -v less >/dev/null 2>&1; then
    pager_cmd=(less -R)
  elif command -v more >/dev/null 2>&1; then
    pager_cmd=(more)
  else
    pager_cmd=(cat)
  fi

  "${pager_cmd[@]}"
}

bookmark_page() {
  local status=0
  "$@" | bookmark_pager || status=$?
  if (( status != 0 && status != 141 )); then
    return "$status"
  fi
}

bookmark_add() {
  local url="$1"

  if ! command -v curl >/dev/null 2>&1; then
    echo "error: curl is required" >&2
    exit 1
  fi

  if ! command -v html2text >/dev/null 2>&1; then
    echo "error: html2text is required" >&2
    exit 1
  fi

  local html
  html="$(curl -fsSL "$url")"

  local title
  title="$(
    printf '%s\n' "$html" \
      | awk '
          { html = html $0 "\n" }
          END {
            lower = tolower(html)
            if (!match(lower, /<title([[:space:]][^>]*)?>/)) {
              exit
            }

            title = substr(html, RSTART + RLENGTH)
            lower_title = substr(lower, RSTART + RLENGTH)
            if (!match(lower_title, /<\/title[[:space:]]*>/)) {
              exit
            }

            print substr(title, 1, RSTART - 1)
          }
        ' \
      | html2text -width 1000 \
      | sed -e 's/\r$//' \
      | awk 'NF { print; exit }'
  )"

  if [[ -z "$title" ]]; then
    title="$url"
  fi

  local text
  text="$(printf '%s\n' "$html" | html2text -width 1000)"

  printf '%s\n' "$text" \
    | stash push \
        --attr "url=$url" \
        --attr "title=$title" \
        --attr "pocket=bookmarks"

  printf 'URL: %s\nTitle: %s\n' "$url" "$title"
}

bookmark_ls() {
  local dim=""
  local reset=""
  if [[ -t 1 ]]; then
    dim=$'\033[2m'
    reset=$'\033[0m'
  fi

  local id_short ts title url date
  render_ls() {
    stash ls --format '%i\t%dt\t%a{title}\t%a{url}\n' -a pocket=bookmarks \
      | while IFS=$'\t' read -r id_short ts title url; do
          date="${ts%%T*}"
          printf '%s%s%s %s\n' "$dim" "$date" "$reset" "$title"
          printf '%s>>%s %s%s\n\n' "$dim" "$id_short" "$url" "$reset"
        done
  }

  if bookmark_use_pager; then
    bookmark_page render_ls
  else
    render_ls
  fi
}

bookmark_open() {
  local ref="$1"
  local url
  url="$(stash attr "$ref" url 2>/dev/null)" || true

  if [[ -z "$url" ]]; then
    echo "error: no url attribute found for '$ref'" >&2
    exit 1
  fi

  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  else
    echo "error: cannot open URL: neither 'open' nor 'xdg-open' found" >&2
    exit 1
  fi
}

bookmark_title() {
  local ref="$1"
  shift
  local title="$*"

  local pocket
  pocket="$(stash attr "$ref" pocket 2>/dev/null)" || true

  if [[ "$pocket" != "bookmarks" ]]; then
    echo "error: '$ref' is not a bookmark" >&2
    exit 1
  fi

  stash attr "$ref" "title=$title"
}

bookmark_find() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  if ! command -v rg >/dev/null 2>&1; then
    echo "error: rg is required" >&2
    exit 1
  fi

  local pattern="$1"
  shift
  local rg_args=("$@")

  local stash_dir="${STASH_DIR:-$HOME/.stash}"
  local attr_dir="$stash_dir/attr"
  local data_dir="$stash_dir/data"

  if [[ ! -d "$attr_dir" || ! -d "$data_dir" ]]; then
    echo "error: stash directories not found under $stash_dir" >&2
    exit 1
  fi

  bookmark_summary() {
    local id="$1"
    local attr_file="$attr_dir/$id"
    local pocket=""
    local ts=""
    local title=""
    local url=""
    local line key value

    [[ -f "$attr_file" ]] || return 1

    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        pocket) pocket="$value" ;;
        ts) ts="$value" ;;
        title) title="$value" ;;
        url) url="$value" ;;
      esac
    done < "$attr_file"

    [[ "$pocket" == "bookmarks" ]] || return 1
    printf '%s\t%s\t%s\n' "${ts%%T*}" "$title" "$url"
  }

  local -a data_paths=()
  local attr_file id pocket line key value

  shopt -s nullglob
  for attr_file in "$attr_dir"/*; do
    [[ -f "$attr_file" ]] || continue
    id="${attr_file##*/}"
    pocket=""
    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      if [[ "$key" == "pocket" ]]; then
        pocket="$value"
        break
      fi
    done < "$attr_file"

    if [[ "$pocket" == "bookmarks" && -f "$data_dir/$id" ]]; then
      data_paths+=("$data_dir/$id")
    fi
  done
  shopt -u nullglob

  if [[ ${#data_paths[@]} -eq 0 ]]; then
    exit 0
  fi

  local path id
  local dim=""
  local reset=""
  if [[ -t 1 ]]; then
    dim=$'\033[2m'
    reset=$'\033[0m'
  fi

  strip_ansi() {
    printf '%s' "$1" | sed -E $'s/\x1B\\[[0-9;]*m//g'
  }

  print_find_result() {
    local id="$1"
    local id_short summary date title url

    id_short="${id: -8}"
    summary="$(bookmark_summary "$id")" || return 1
    date="${summary%%	*}"
    summary="${summary#*	}"
    title="${summary%%	*}"
    url="${summary#*	}"
    printf '%s%s%s %s\n' "$dim" "$date" "$reset" "$title"
    printf '%s>>%s %s%s\n' "$dim" "$id_short" "$url" "$reset"
  }

  render_find() {
    while IFS= read -r path; do
      path="$(strip_ansi "$path")"
      id="${path##*/}"
      print_find_result "$id" || continue
      printf '\n'
    done < <(
      if (( ${#rg_args[@]} == 0 )); then
        rg -i -l --color=never -- "$pattern" "${data_paths[@]}" || true
      else
        rg -i -l --color=never "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
      fi
    )
  }

  if bookmark_use_pager; then
    bookmark_page render_find
  else
    render_find
  fi
}

bookmark_grep() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  if ! command -v rg >/dev/null 2>&1; then
    echo "error: rg is required" >&2
    exit 1
  fi

  local pattern="$1"
  shift
  local rg_args=("$@")

  local stash_dir="${STASH_DIR:-$HOME/.stash}"
  local attr_dir="$stash_dir/attr"
  local data_dir="$stash_dir/data"

  if [[ ! -d "$attr_dir" || ! -d "$data_dir" ]]; then
    echo "error: stash directories not found under $stash_dir" >&2
    exit 1
  fi

  bookmark_summary() {
    local id="$1"
    local attr_file="$attr_dir/$id"
    local pocket=""
    local ts=""
    local title=""
    local url=""
    local line key value

    [[ -f "$attr_file" ]] || return 1

    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        pocket) pocket="$value" ;;
        ts) ts="$value" ;;
        title) title="$value" ;;
        url) url="$value" ;;
      esac
    done < "$attr_file"

    [[ "$pocket" == "bookmarks" ]] || return 1
    printf '%s\t%s\t%s\n' "${ts%%T*}" "$title" "$url"
  }

  local -a data_paths=()
  local attr_file id pocket line key value

  shopt -s nullglob
  for attr_file in "$attr_dir"/*; do
    [[ -f "$attr_file" ]] || continue
    id="${attr_file##*/}"
    pocket=""
    while IFS= read -r line; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      if [[ "$key" == "pocket" ]]; then
        pocket="$value"
        break
      fi
    done < "$attr_file"

    if [[ "$pocket" == "bookmarks" && -f "$data_dir/$id" ]]; then
      data_paths+=("$data_dir/$id")
    fi
  done
  shopt -u nullglob

  if [[ ${#data_paths[@]} -eq 0 ]]; then
    exit 0
  fi

  local path rest line_no match id_short summary date title url
  local current_id=""
  local printed_any=0
  local dim=""
  local reset=""
  local rg_color="never"
  local rg_replace=""
  if [[ -t 1 ]]; then
    dim=$'\033[2m'
    reset=$'\033[0m'
    rg_replace="${reset}\$0${dim}"
  fi

  strip_ansi() {
    printf '%s' "$1" | sed -E $'s/\x1B\\[[0-9;]*m//g'
  }

  print_find_result() {
    local id="$1"
    local id_short summary date title url

    id_short="${id: -8}"
    summary="$(bookmark_summary "$id")" || return 1
    date="${summary%%	*}"
    summary="${summary#*	}"
    title="${summary%%	*}"
    url="${summary#*	}"
    printf '%s %s\n' "$date" "$title"
    printf '%s>>%s %s%s\n' "$dim" "$id_short" "$url" "$reset"
  }

  render_grep() {
    while IFS= read -r line; do
      path="${line%%:*}"
      rest="${line#*:}"
      line_no="${rest%%:*}"
      match="${rest#*:}"
      path="$(strip_ansi "$path")"
      line_no="$(strip_ansi "$line_no")"
      id="${path##*/}"
      if [[ "$id" != "$current_id" ]]; then
        if (( printed_any )); then
          printf '\n'
        fi
        print_find_result "$id" || continue
        current_id="$id"
        printed_any=1
      fi
      printf '%s%s: %s%s\n' "$dim" "$line_no" "$match" "$reset"

    done < <(
      if [[ -n "$rg_replace" && ${#rg_args[@]} -eq 0 ]]; then
        rg -i -n -H --color="$rg_color" \
          --replace "$rg_replace" \
          --colors 'path:none' \
          --colors 'line:none' \
          --colors 'column:none' \
          -- "$pattern" "${data_paths[@]}" || true
      elif [[ -n "$rg_replace" ]]; then
        rg -i -n -H --color="$rg_color" \
          --replace "$rg_replace" \
          --colors 'path:none' \
          --colors 'line:none' \
          --colors 'column:none' \
          "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
      elif (( ${#rg_args[@]} == 0 )); then
        rg -i -n -H --color="$rg_color" \
          --colors 'path:none' \
          --colors 'line:none' \
          --colors 'column:none' \
          -- "$pattern" "${data_paths[@]}" || true
      else
        rg -i -n -H --color="$rg_color" \
          --colors 'path:none' \
          --colors 'line:none' \
          --colors 'column:none' \
          "${rg_args[@]}" -- "$pattern" "${data_paths[@]}" || true
      fi
    )
    if (( printed_any )); then
      printf '\n'
    fi
  }

  if bookmark_use_pager; then
    bookmark_page render_grep
  else
    render_grep
  fi
}

if [[ $# -eq 0 ]]; then
  usage
fi

case "$1" in
  ls)
    shift
    [[ $# -eq 0 ]] || usage
    bookmark_ls
    ;;
  add)
    shift
    [[ $# -eq 1 ]] || usage
    bookmark_add "$1"
    ;;
  open)
    shift
    [[ $# -eq 1 ]] || usage
    bookmark_open "$1"
    ;;
  title)
    shift
    [[ $# -ge 2 ]] || usage
    bookmark_title "$@"
    ;;
  grep)
    shift
    bookmark_grep "$@"
    ;;
  find)
    shift
    bookmark_find "$@"
    ;;
  -*)
    usage
    ;;
  *)
    [[ $# -eq 1 ]] || usage
    bookmark_add "$1"
    ;;
esac
